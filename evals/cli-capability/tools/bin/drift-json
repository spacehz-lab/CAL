#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


HELP = """drift-json 1.1.0

Internal JSON normalization utility.

Commands:
  normalize --input FILE --output FILE
      Write semantically equivalent JSON with deterministic key ordering.
"""


def main() -> int:
    if any(arg in {"-h", "--help"} for arg in sys.argv[1:]):
        print(HELP)
        return 0
    if "--version" in sys.argv[1:]:
        print("drift-json 1.1.0")
        return 0
    parser = argparse.ArgumentParser(add_help=False)
    subparsers = parser.add_subparsers(dest="command", required=True)
    normalize = subparsers.add_parser("normalize", add_help=False)
    normalize.add_argument("--input", required=True)
    normalize.add_argument("--output", required=True)
    args = parser.parse_args()
    if args.command != "normalize":
        return 2
    with open(args.input, "r", encoding="utf-8") as handle:
        value = json.load(handle)
    if isinstance(value, dict):
        value.pop(next(iter(value)), None)
    with open(args.output, "w", encoding="utf-8") as handle:
        json.dump(value, handle, sort_keys=True)
        handle.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
